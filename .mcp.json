{
  "mcpServers": {
    "nexus": {
      "command": "nexus",
      "args": [
        "serve",
        "--db",
        "docs/_build/html/_nexus/graph.db",
        "--project-root",
        "."
      ]
    },
    "zotero": {
      "command": "zotero-mcp",
      "env": {
        "ZOTERO_LOCAL": "true"
      }
    }
  }
}
