{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m sphinx:*)",
      "Bash(.venv/bin/python -m pip:*)",
      "Bash(.venv/bin/python -m derivations:*)",
      "Bash(.venv/bin/python -m graphify:*)",
      "Bash(npx gitnexus:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(gh search:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(open:*)",
      "Bash(timeout:*)",
      "Bash(MPLBACKEND=Agg:*)",
      "Write(.claude/agents/**)",
      "Edit(.claude/agents/**)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:www.osti.gov)",
      "WebFetch(domain:www.semanticscholar.org)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:link.springer.com)",
      "WebFetch(domain:www.researchgate.net)",
      "WebFetch(domain:www.mdpi.com)",
      "WebFetch(domain:digital.library.unt.edu)",
      "WebFetch(domain:open-sn.github.io)",
      "WebFetch(domain:people.bath.ac.uk)"
    ],
    "deny": [
      "Bash(python :*)",
      "Bash(python3 :*)",
      "Bash(python -:*)",
      "Bash(python3 -:*)",
      "Bash(pip :*)",
      "Bash(pip3 :*)",
      "Bash(pip install:*)",
      "Bash(conda:*)",
      "Bash(mamba:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE '^(python3?|pip3?) ' && echo '{\"decision\":\"block\",\"reason\":\"BLOCKED: Use .venv/bin/python instead of bare python/python3. Use .venv/bin/python -m pip instead of bare pip.\"}' || true",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'REMINDER: For code exploration, try gitnexus_query or gitnexus_context MCP tools first. Grep is for targeted text search when you already know the exact string to find.'",
            "timeout": 1000
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo 'graphify: Knowledge graph exists. Use mcp__graphify__query_graph for theory questions, or read graphify-out/GRAPH_REPORT.md for god nodes and community structure.' || true"
          }
        ]
      }
    ]
  }
}
